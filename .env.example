# Copie para .env e ajuste os valores. NÃO comite o .env real.
# cp .env.example .env

# =============================================================
# PostgreSQL (usado pelo serviço `db` do docker-compose)
# =============================================================
POSTGRES_USER=controlbio
POSTGRES_PASSWORD=controlbio
POSTGRES_DB=controlbio_ponto
POSTGRES_PORT=5432

# =============================================================
# Aplicação
# =============================================================
NODE_ENV=development
APP_PORT=3000
# URL pública da app (usada em links, callbacks de auth, etc.)
APP_URL=http://localhost:3000

# =============================================================
# Banco de dados (usado pela aplicação / ORM)
# =============================================================
# Usamos Drizzle + driver postgres-js. NÃO inclua `?schema=public` (sintaxe do
# Prisma): o postgres-js repassa `schema` como parâmetro de conexão e o servidor
# rejeita (FATAL 42704). O search_path padrão já é "public".
# - Dentro do docker-compose, o host é "db" (nome do serviço).
# - Rodando a app localmente (npm run dev) contra o banco do compose, use "localhost".
DATABASE_URL=postgresql://controlbio:controlbio@localhost:5432/controlbio_ponto

# =============================================================
# Autenticação / Sessão
# =============================================================
# Segredo para assinar tokens de sessão/JWT. Gere um valor forte:
#   openssl rand -base64 32      (ou: npx auth secret)
# NUNCA reutilize este valor de exemplo em produção.
AUTH_SECRET=troque-por-um-segredo-aleatorio-forte

# Tempo de expiração da sessão (em segundos). Padrão: 8h.
SESSION_MAX_AGE=28800

# =============================================================
# Seed do admin inicial (usado por `npm run db:seed`)
# =============================================================
# Cria o primeiro usuário admin para destravar o acesso. Idempotente.
# Troque a senha após o primeiro login.
SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@controlbio.com.br
SEED_ADMIN_PASSWORD=troque-esta-senha